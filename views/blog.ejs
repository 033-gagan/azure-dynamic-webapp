<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title><%= blog.title %> — Quill</title>
  <style>
    .blog-hero {
      position: relative; overflow: hidden;
      max-height: 480px; min-height: 280px;
    }
    .blog-hero img {
      width: 100%; height: 100%; object-fit: cover;
      max-height: 480px; filter: brightness(0.55);
      display: block;
    }
    .blog-hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, var(--bg) 0%, rgba(12,12,14,0.3) 60%, transparent 100%);
    }
    .blog-hero-content {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 2.5rem 0 2rem;
    }

    .blog-layout { max-width: 760px; margin: 0 auto; padding: 0 1.5rem; }

    .blog-meta-line {
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 1.2rem; flex-wrap: wrap;
    }
    .author-chip {
      display: flex; align-items: center; gap: 0.6rem;
    }
    .author-chip img {
      width: 32px; height: 32px; border-radius: 50%;
      border: 1.5px solid var(--accent); object-fit: cover;
    }
    .author-chip span { font-size: 0.85rem; font-weight: 500; color: var(--text); }

    .blog-title-h1 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 900; line-height: 1.12;
      color: var(--text); letter-spacing: -0.03em;
    }

    /* Body area */
    .blog-content-area { padding: 3rem 0; }

    .blog-body {
      font-size: 1.06rem; line-height: 1.85;
      color: #ccc9c3;
    }

    /* Comments */
    .comments-section {
      border-top: 1px solid var(--border);
      padding-top: 3rem; margin-top: 3rem;
    }
    .comments-title {
      font-family: var(--font-display);
      font-size: 1.5rem; font-weight: 700;
      margin-bottom: 1.75rem; color: var(--text);
    }
    .comment-form-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.5rem; margin-bottom: 2rem;
    }
    .comment-form-label {
      font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--muted); font-weight: 500; margin-bottom: 0.75rem; display: block;
    }

    .comment-item {
      display: flex; gap: 1rem;
      padding: 1.2rem 0;
      border-bottom: 1px solid var(--border);
      animation: fadeUp 0.4s ease both;
    }
    .comment-item:last-child { border-bottom: none; }
    .comment-avatar img {
      width: 36px; height: 36px; border-radius: 50%;
      object-fit: cover; border: 1px solid var(--border);
      flex-shrink: 0;
    }
    .comment-body-wrap { flex: 1; }
    .comment-author {
      font-size: 0.82rem; font-weight: 600;
      color: var(--accent); margin-bottom: 0.3rem;
      letter-spacing: 0.03em;
    }
    .comment-text {
      font-size: 0.92rem; color: #b5b0a8;
      white-space: pre-wrap; line-height: 1.65;
    }
  </style>
</head>
<body>
  <%- include('./partials/nav') %>

  <div class="blog-hero page-fade">
    <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>">
    <div class="blog-hero-overlay"></div>
    <div class="blog-hero-content">
      <div class="blog-layout">
        <div class="blog-meta-line">
          <span class="tag-pill">Article</span>
          <div class="author-chip">
            <img src="<%= blog.createdBy.profileImageURL %>" alt="<%= blog.createdBy.username %>">
            <span><%= blog.createdBy.username %></span>
          </div>
        </div>
        <h1 class="blog-title-h1"><%= blog.title %></h1>
      </div>
    </div>
  </div>

  <div class="blog-layout page-fade2">
    <div class="blog-content-area">
      <p class="blog-body"><%= blog.body %></p>
    </div>

    <div class="comments-section page-fade3">
      <h2 class="comments-title">
        <i class="bi bi-chat-dots me-2" style="color:var(--accent);font-size:1.2rem;"></i>
        Comments <span style="color:var(--muted);font-weight:400;font-size:1rem;">(<%= comments.length %>)</span>
      </h2>

      <% if (locals.user) { %>
        <div class="comment-form-wrap">
          <label class="comment-form-label"><i class="bi bi-pencil me-1"></i>Leave a comment</label>
          <form action="/blog/comment/<%= blog._id %>" method="post">
            <div class="mb-3">
              <textarea class="form-control" id="content" name="content" rows="3"
                placeholder="Share your thoughts..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-send me-1"></i>Post Comment
            </button>
          </form>
        </div>
      <% } %>

      <div>
        <% if (comments.length === 0) { %>
          <div style="text-align:center;padding:2.5rem 0;color:var(--muted);">
            <i class="bi bi-chat-square-text" style="font-size:2rem;display:block;margin-bottom:0.75rem;"></i>
            No comments yet. Start the conversation.
          </div>
        <% } else { %>
          <% comments.forEach((comment, i) => { %>
            <div class="comment-item" style="animation-delay:<%= i * 0.05 %>s">
              <div class="comment-avatar">
                <img src="<%= comment.createdBy.profileImageURL %>" alt="<%= comment.createdBy.username %>">
              </div>
              <div class="comment-body-wrap">
                <div class="comment-author"><%= comment.createdBy.username %></div>
                <div class="comment-text"><%= comment.content %></div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('./partials/script') %>
</body>
</html>
