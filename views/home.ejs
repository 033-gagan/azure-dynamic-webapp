<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>Quill — Home</title>
  <style>
    /* ── Hero ── */
    .hero-section {
      position: relative;
      min-height: 92vh;
      display: flex; align-items: center; justify-content: center;
      border-bottom: 1px solid var(--border);
      margin-bottom: 4rem;
      overflow: hidden;
    }

    /* deep radial glow behind everything */
    .hero-section::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 70% 55% at 50% 40%, rgba(201,169,110,0.10) 0%, transparent 70%),
        radial-gradient(ellipse 40% 30% at 30% 60%, rgba(100,80,200,0.05) 0%, transparent 60%);
      pointer-events: none;
    }

    /* subtle grid lines */
    .hero-section::after {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 0%, transparent 100%);
    }

    .hero-inner {
      position: relative; z-index: 2;
      display: grid;
      grid-template-columns: 1fr 480px;
      align-items: center;
      gap: 3rem;
      max-width: 1200px;
      margin: 0 auto;
      padding: 5rem 2rem 4rem;
      width: 100%;
    }

    /* ── 3D Text ── */
    .hero-text-wrap { }

    .hero-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1.4rem; display: flex; align-items: center; gap: 0.7rem;
    }
    .hero-eyebrow::before {
      content: '';
      display: inline-block; width: 30px; height: 1px; background: var(--accent);
    }

    .hero-title-3d {
      font-family: var(--font-display);
      font-size: clamp(3.5rem, 6vw, 5.5rem);
      font-weight: 900;
      line-height: 1.0;
      letter-spacing: -0.03em;
      color: #e8e6e1;
      /* 3D extrude effect */
      text-shadow:
        1px 1px 0 #b8935a,
        2px 2px 0 #a8834a,
        3px 3px 0 #98733a,
        4px 4px 0 #88632a,
        5px 5px 0 #78531a,
        6px 6px 0 #68430a,
        7px 7px 0 rgba(0,0,0,0.4),
        8px 8px 12px rgba(0,0,0,0.5);
      position: relative;
    }

    .hero-title-3d em {
      color: #c9a96e;
      font-style: italic;
      text-shadow:
        1px 1px 0 #e8c98a,
        2px 2px 0 #d8b97a,
        3px 3px 0 #c8a96a,
        4px 4px 0 #b8994a,
        5px 5px 0 #a8893a,
        6px 6px 0 #987920,
        7px 7px 0 rgba(0,0,0,0.4),
        8px 8px 12px rgba(0,0,0,0.5);
    }

    /* shine sweep animation */
    @keyframes shine {
      0%   { left: -120%; }
      60%, 100% { left: 160%; }
    }
    .hero-title-3d-wrap {
      position: relative; display: inline-block; overflow: hidden;
    }
    .hero-title-3d-wrap::after {
      content: '';
      position: absolute; top: 0; left: -120%;
      width: 60%; height: 100%;
      background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.12) 50%, transparent 60%);
      animation: shine 4s ease-in-out infinite 1.5s;
      pointer-events: none;
    }

    .hero-sub {
      color: var(--muted); font-size: 1.05rem; max-width: 460px;
      margin: 1.6rem 0 2.2rem; line-height: 1.7;
    }

    .hero-cta-row { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
    .hero-cta-primary {
      background: var(--accent); color: #0c0c0e;
      border: none; border-radius: 4px; padding: 0.8rem 2rem;
      font-weight: 700; font-size: 0.85rem; letter-spacing: 0.07em; text-transform: uppercase;
      text-decoration: none; cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(201,169,110,0.2);
    }
    .hero-cta-primary:hover {
      background: var(--accent2); transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(201,169,110,0.35);
    }
    .hero-cta-secondary {
      color: var(--muted); font-size: 0.85rem; letter-spacing: 0.06em;
      text-transform: uppercase; text-decoration: none; font-weight: 500;
      transition: color 0.2s;
    }
    .hero-cta-secondary:hover { color: var(--accent); }

    /* ── 3D Book Canvas ── */
    #book-canvas {
      width: 100%; height: 480px;
      display: block; cursor: grab;
    }
    #book-canvas:active { cursor: grabbing; }

    .canvas-hint {
      text-align: center; font-size: 0.7rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted);
      margin-top: -0.5rem; opacity: 0.6;
    }

    /* floating particles */
    @keyframes float-up {
      0%   { transform: translateY(0) scale(1); opacity: 0.7; }
      100% { transform: translateY(-140px) scale(0.3); opacity: 0; }
    }
    .particle {
      position: absolute; border-radius: 50%;
      background: var(--accent); pointer-events: none;
      animation: float-up linear infinite;
    }

    /* ── Cards section ── */
    .section-header {
      display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2.5rem;
    }
    .section-header h2 {
      font-family: var(--font-display);
      font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--muted); font-weight: 400; white-space: nowrap;
    }
    .section-header .rule { flex: 1; }

    .blogs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 1.75rem;
    }

    .blog-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      display: flex; flex-direction: column;
      transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
      animation: fadeUp 0.5s ease both;
    }
    .blog-card:hover {
      transform: translateY(-6px);
      border-color: rgba(201,169,110,0.25);
      box-shadow: 0 24px 60px rgba(0,0,0,0.45);
    }
    .blog-card-img-wrap {
      position: relative; overflow: hidden; aspect-ratio: 16/9;
      background: var(--surface2);
    }
    .blog-card-img-wrap img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.45s cubic-bezier(.22,.68,0,1.1), filter 0.3s;
      filter: brightness(0.85);
    }
    .blog-card:hover .blog-card-img-wrap img { transform: scale(1.06); filter: brightness(1); }
    .blog-card-img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(12,12,14,0.7) 0%, transparent 55%);
    }
    .blog-card-body {
      padding: 1.25rem 1.4rem 1.5rem;
      flex: 1; display: flex; flex-direction: column; gap: 0.75rem;
    }
    .blog-card-title {
      font-family: var(--font-display);
      font-size: 1.15rem; font-weight: 700;
      color: var(--text); line-height: 1.3; letter-spacing: -0.01em;
    }
    .blog-card-link {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase;
      font-weight: 600; color: var(--accent); text-decoration: none;
      transition: gap 0.2s, color 0.2s; margin-top: auto;
    }
    .blog-card-link:hover { gap: 0.7rem; color: var(--accent2); }

    .empty-state { text-align: center; padding: 6rem 2rem; }
    .empty-state-icon { font-size: 3rem; color: var(--muted); margin-bottom: 1rem; }
    .empty-state h3 { font-family: var(--font-display); font-size: 1.6rem; color: var(--text); margin-bottom: 0.5rem; }
    .empty-state p { color: var(--muted); }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; padding: 3rem 1.5rem; }
      #book-canvas { height: 320px; }
      .hero-title-3d { font-size: clamp(2.5rem, 8vw, 4rem); }
    }
  </style>
</head>
<body>
  <%- include('./partials/nav') %>

  <!-- HERO -->
  <div class="hero-section page-fade">
    <div class="hero-inner">
      <!-- Left: Text -->
      <div class="hero-text-wrap">
        <span class="hero-eyebrow">Welcome to Quill</span>
        <div class="hero-title-3d-wrap">
          <h1 class="hero-title-3d">Stories<br>Worth<br><em>Reading.</em></h1>
        </div>
        <p class="hero-sub">Discover thoughtful writing from voices around the world. Ideas that linger, stories that move.</p>
        <div class="hero-cta-row">
          <a href="#latest" class="hero-cta-primary">Explore Stories</a>
          <a href="/user/signup" class="hero-cta-secondary">Start writing →</a>
        </div>
      </div>

      <!-- Right: 3D Book -->
      <div>
        <canvas id="book-canvas"></canvas>
        <p class="canvas-hint">drag to rotate</p>
      </div>
    </div>
  </div>

  <!-- BLOG GRID -->
  <div class="container pb-5 page-fade2" id="latest">
    <div class="section-header">
      <h2>Latest Posts</h2>
      <div class="rule"></div>
      <span class="tag-pill"><%= blogs.length %> articles</span>
    </div>

    <% if (blogs.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-journal-text"></i></div>
        <h3>No stories yet</h3>
        <p>Be the first to share something worth reading.</p>
      </div>
    <% } else { %>
      <div class="blogs-grid">
        <% blogs.forEach((blog, i) => { %>
          <div class="blog-card" style="animation-delay: <%= i * 0.06 %>s">
            <div class="blog-card-img-wrap">
              <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>">
              <div class="blog-card-img-overlay"></div>
            </div>
            <div class="blog-card-body">
              <h2 class="blog-card-title"><%= blog.title %></h2>
              <a href="/blog/<%= blog._id %>" class="blog-card-link">
                Read article <i class="bi bi-arrow-right"></i>
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <%- include('./partials/script') %>

  <!-- Three.js 3D Book -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script>
  (function() {
    const canvas = document.getElementById('book-canvas');
    const W = canvas.parentElement.offsetWidth;
    const H = canvas.parentElement.offsetWidth < 900 ? 320 : 480;
    canvas.width = W; canvas.height = H;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(W, H);
    renderer.shadowMap.enabled = true;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, W / H, 0.1, 100);
    camera.position.set(0, 1.2, 6);

    // Lights
    const ambient = new THREE.AmbientLight(0xffeedd, 0.5);
    scene.add(ambient);

    const keyLight = new THREE.DirectionalLight(0xfff4e0, 1.8);
    keyLight.position.set(4, 6, 5);
    keyLight.castShadow = true;
    scene.add(keyLight);

    const rimLight = new THREE.DirectionalLight(0xc9a96e, 0.6);
    rimLight.position.set(-5, 2, -3);
    scene.add(rimLight);

    const fillLight = new THREE.PointLight(0x8866ff, 0.3, 20);
    fillLight.position.set(0, -2, 4);
    scene.add(fillLight);

    // Book group
    const book = new THREE.Group();
    scene.add(book);

    // Materials
    const coverMat = new THREE.MeshStandardMaterial({
      color: 0x1a1208, roughness: 0.55, metalness: 0.08
    });
    const spineMat = new THREE.MeshStandardMaterial({
      color: 0x0f0b04, roughness: 0.6, metalness: 0.05
    });
    const pageMat = new THREE.MeshStandardMaterial({
      color: 0xf0ead8, roughness: 0.9, metalness: 0.0
    });
    const accentMat = new THREE.MeshStandardMaterial({
      color: 0xc9a96e, roughness: 0.3, metalness: 0.6,
      emissive: 0xc9a96e, emissiveIntensity: 0.08
    });

    // Book dimensions
    const BW=3.2, BH=6.0, BD=0.90;
    const coverThick = 0.045;

    // Front cover
    const frontCover = new THREE.Mesh(
      new THREE.BoxGeometry(BW, BH, coverThick),
      coverMat
    );
    frontCover.position.set(0, 0, BD / 2 + coverThick / 2);
    book.add(frontCover);

    // Back cover
    const backCover = new THREE.Mesh(
      new THREE.BoxGeometry(BW, BH, coverThick),
      coverMat
    );
    backCover.position.set(0, 0, -BD / 2 - coverThick / 2);
    book.add(backCover);

    // Spine
    const spine = new THREE.Mesh(
      new THREE.BoxGeometry(coverThick, BH, BD + coverThick * 2),
      spineMat
    );
    spine.position.set(-BW / 2 - coverThick / 2, 0, 0);
    book.add(spine);

    // Pages block
    const pages = new THREE.Mesh(
      new THREE.BoxGeometry(BW - 0.06, BH - 0.06, BD),
      pageMat
    );
    book.add(pages);

    // Gold accent band on cover
    const band = new THREE.Mesh(
      new THREE.BoxGeometry(BW * 0.85, 0.025, coverThick + 0.002),
      accentMat
    );
    band.position.set(0.04, BH * 0.25, BD / 2 + coverThick / 2 + 0.001);
    book.add(band);

    const band2 = new THREE.Mesh(
      new THREE.BoxGeometry(BW * 0.85, 0.025, coverThick + 0.002),
      accentMat
    );
    band2.position.set(0.04, BH * 0.25 - 0.08, BD / 2 + coverThick / 2 + 0.001);
    book.add(band2);

    // Gold corner ornaments
    const cornerGeo = new THREE.BoxGeometry(0.18, 0.025, coverThick + 0.002);
    const corners = [
      [-BW*0.38,  BH*0.43], [BW*0.38,  BH*0.43],
      [-BW*0.38, -BH*0.43], [BW*0.38, -BH*0.43]
    ];
    corners.forEach(([cx, cy]) => {
      const c1 = new THREE.Mesh(cornerGeo, accentMat);
      c1.position.set(cx, cy, BD / 2 + coverThick / 2 + 0.001);
      book.add(c1);
      const c2 = new THREE.Mesh(
        new THREE.BoxGeometry(0.025, 0.18, coverThick + 0.002), accentMat
      );
      c2.position.set(cx, cy, BD / 2 + coverThick / 2 + 0.001);
      book.add(c2);
    });

    // Page edge lines (thin gold lines on right side)
    for (let i = 0; i < 6; i++) {
      const line = new THREE.Mesh(
        new THREE.BoxGeometry(0.006, BH - 0.1, BD - 0.02),
        new THREE.MeshStandardMaterial({ color: 0xd4aa60, roughness: 0.4, metalness: 0.5 })
      );
      line.position.set(BW / 2 - 0.01 - i * 0.009, 0, 0);
      book.add(line);
    }

    // Floating particles around book
    const particles = [];
    const particleGeo = new THREE.SphereGeometry(0.022, 6, 6);
    const particleMat = new THREE.MeshStandardMaterial({
      color: 0xc9a96e, emissive: 0xc9a96e, emissiveIntensity: 0.4, roughness: 0.3
    });
    for (let i = 0; i < 18; i++) {
      const p = new THREE.Mesh(particleGeo, particleMat);
      p.userData = {
        angle: Math.random() * Math.PI * 2,
        radius: 1.4 + Math.random() * 0.8,
        speed: 0.003 + Math.random() * 0.004,
        yOffset: (Math.random() - 0.5) * 2.5,
        ySpeed: 0.008 + Math.random() * 0.012,
        yPhase: Math.random() * Math.PI * 2,
        scale: 0.4 + Math.random() * 0.8
      };
      p.scale.setScalar(p.userData.scale);
      scene.add(p);
      particles.push(p);
    }

    // Mouse drag
    let isDragging = false, prevX = 0, prevY = 0;
    let rotY = 0.3, rotX = -0.15;
    let velY = 0.004, velX = 0;

    canvas.addEventListener('mousedown', e => { isDragging = true; prevX = e.clientX; prevY = e.clientY; });
    canvas.addEventListener('touchstart', e => { isDragging = true; prevX = e.touches[0].clientX; prevY = e.touches[0].clientY; });
    window.addEventListener('mouseup', () => isDragging = false);
    window.addEventListener('touchend', () => isDragging = false);

    window.addEventListener('mousemove', e => {
      if (!isDragging) return;
      velY = (e.clientX - prevX) * 0.012;
      velX = (e.clientY - prevY) * 0.008;
      prevX = e.clientX; prevY = e.clientY;
    });
    window.addEventListener('touchmove', e => {
      if (!isDragging) return;
      velY = (e.touches[0].clientX - prevX) * 0.012;
      velX = (e.touches[0].clientY - prevY) * 0.008;
      prevX = e.touches[0].clientX; prevY = e.touches[0].clientY;
    });

    // Animate
    const clock = new THREE.Clock();
    function animate() {
      requestAnimationFrame(animate);
      const t = clock.getElapsedTime();

      if (!isDragging) {
        velY *= 0.97;
        velX *= 0.94;
        velY += 0.0018; // auto-spin
      }
      rotY += velY;
      rotX += velX;
      rotX = Math.max(-0.5, Math.min(0.5, rotX));

      book.rotation.y = rotY;
      book.rotation.x = rotX;
      book.position.y = Math.sin(t * 0.6) * 0.08;

      // animate particles
      particles.forEach(p => {
        p.userData.angle += p.userData.speed;
        const a = p.userData.angle;
        const r = p.userData.radius;
        p.position.x = Math.cos(a) * r * 0.7;
        p.position.z = Math.sin(a) * r * 0.4 + 0.5;
        p.position.y = p.userData.yOffset + Math.sin(t * p.userData.ySpeed * 60 + p.userData.yPhase) * 0.35;
        p.material.emissiveIntensity = 0.25 + Math.sin(t * 2 + p.userData.yPhase) * 0.2;
      });

      renderer.render(scene, camera);
    }
    animate();

    // Resize
    window.addEventListener('resize', () => {
      const nw = canvas.parentElement.offsetWidth;
      renderer.setSize(nw, H);
      camera.aspect = nw / H;
      camera.updateProjectionMatrix();
    });
  })();
  </script>
</body>
</html>
