<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
  :root {
    --bg: #0c0c0e;
    --surface: #141416;
    --surface2: #1c1c1f;
    --border: rgba(255,255,255,0.07);
    --text: #e8e6e1;
    --muted: #7a7875;
    --accent: #c9a96e;
    --accent2: #e8c98a;
    --danger: #d95f5f;
    --radius: 4px;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'DM Sans', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 3px; }

  /* Navbar */
  .navbar {
    background: rgba(12,12,14,0.92) !important;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    padding: 1.1rem 2rem;
    position: sticky; top: 0; z-index: 1000;
  }
  .navbar-brand {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.65rem;
    color: var(--accent) !important;
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .nav-link {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted) !important;
    font-weight: 500;
    transition: color 0.2s;
    padding: 0.4rem 1rem !important;
  }
  .nav-link:hover, .nav-link.active { color: var(--accent) !important; }

  .btn-nav-cta {
    background: var(--accent) !important;
    color: #0c0c0e !important;
    border-radius: var(--radius) !important;
    font-weight: 700 !important;
    transition: background 0.2s, transform 0.15s !important;
  }
  .btn-nav-cta:hover { background: var(--accent2) !important; transform: translateY(-1px); }

  .dropdown-menu {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    padding: 0.5rem;
  }
  .dropdown-item { color: var(--text); font-size: 0.875rem; border-radius: 2px; padding: 0.5rem 0.75rem; transition: background 0.15s; }
  .dropdown-item:hover { background: var(--border); color: var(--accent); }
  .navbar-toggler { border-color: var(--border) !important; }
  .navbar-toggler-icon { filter: invert(0.7); }

  /* Alerts */
  .alert-danger {
    background: rgba(217,95,95,0.1);
    border: 1px solid rgba(217,95,95,0.3);
    color: #f09090;
    border-radius: var(--radius);
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  /* Buttons */
  .btn-primary {
    background: var(--accent); border: none;
    color: #0c0c0e; font-weight: 700;
    font-size: 0.82rem; letter-spacing: 0.07em; text-transform: uppercase;
    border-radius: var(--radius); padding: 0.65rem 1.75rem;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .btn-primary:hover {
    background: var(--accent2); color: #0c0c0e;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(201,169,110,0.25);
  }
  .btn-primary:active { transform: translateY(0); }

  /* Forms */
  .form-label {
    font-size: 0.75rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--muted);
    font-weight: 500; margin-bottom: 0.4rem;
  }
  .form-control, textarea.form-control {
    background: var(--surface2) !important;
    border: 1px solid var(--border) !important;
    color: var(--text) !important;
    border-radius: var(--radius) !important;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-control::placeholder { color: var(--muted) !important; }
  .form-control:focus, textarea.form-control:focus {
    border-color: var(--accent) !important;
    box-shadow: 0 0 0 3px rgba(201,169,110,0.12) !important;
    outline: none;
  }

  /* Page animation */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .page-fade  { animation: fadeUp 0.5s cubic-bezier(.22,.68,0,1.1) both; }
  .page-fade2 { animation: fadeUp 0.5s cubic-bezier(.22,.68,0,1.1) 0.1s both; }
  .page-fade3 { animation: fadeUp 0.5s cubic-bezier(.22,.68,0,1.1) 0.2s both; }

  /* Utility */
  .tag-pill {
    font-family: var(--font-mono);
    font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); border: 1px solid rgba(201,169,110,0.3);
    border-radius: 2px; padding: 0.12rem 0.5rem; display: inline-block;
  }
  .rule { height: 1px; background: var(--border); }
</style>
